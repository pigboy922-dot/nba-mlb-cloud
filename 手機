function getCompletedGameForTeam(conf, event, teamId, cutoffMs) {
  if (!isOfficialGame(conf, event)) return null;
  if (!event?.status?.type?.completed) return null;
  const gameMs = new Date(event.date).getTime();
  if (!(gameMs < cutoffMs)) return null;
  const comp = event.competitions?.[0];
  const competitors = comp?.competitors || [];
  const mine = competitors.find(c => String(c.team?.id) === String(teamId));
  const opp = competitors.find(c => String(c.team?.id) !== String(teamId));
  if (!mine || !opp) return null;
  const pf = Number(mine.score), pa = Number(opp.score);
  if (Number.isNaN(pf) || Number.isNaN(pa)) return null;
  return { pf, pa, date:event.date, gameMs, id:event.id, homeAway: mine.homeAway };
