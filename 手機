      odds?.overUnderLine, odds?.underOver
    ].map(toNum).find(v => v !== null);

    let leftSpread = getTeamSideSpread(odds, leftCompetitor);
    let rightSpread = getTeamSideSpread(odds, rightCompetitor);

    if (leftSpread === null && rightSpread === null) {
      const rawSpread = [
        odds?.spread, odds?.pointSpread, odds?.line
      ].map(toNum).find(v => v !== null);
      if (rawSpread !== null) {
        if (textHasTeamAlias(details, leftCompetitor?.team)) {
          leftSpread = rawSpread < 0 ? rawSpread : -Math.abs(rawSpread);
          rightSpread = -leftSpread;
        } else if (textHasTeamAlias(details, rightCompetitor?.team)) {
