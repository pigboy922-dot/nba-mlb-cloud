    if (market.total === null && total !== null) market.total = total;
    if (market.leftSpread === null && leftSpread !== null) market.leftSpread = leftSpread;
    if (market.rightSpread === null && rightSpread !== null) market.rightSpread = rightSpread;
    if (!market.provider && provider) market.provider = provider;
    if (!market.details && details) market.details = details;
  }

  if (market.leftSpread !== null && market.rightSpread === null) market.rightSpread = -market.leftSpread;
  if (market.rightSpread !== null && market.leftSpread === null) market.leftSpread = -market.rightSpread;

  if (market.leftSpread !== null && market.rightSpread !== null) {
    if (market.leftSpread < market.rightSpread) {
      market.favoriteSide = 'left';
      market.spread = Math.abs(market.leftSpread);
    } else if (market.rightSpread < market.leftSpread) {
