const TEAM_NAME_ZH = {
  nba: {'Atlanta Hawks':'亞特蘭大老鷹','Boston Celtics':'波士頓塞爾提克','Brooklyn Nets':'布魯克林籃網','Charlotte Hornets':'夏洛特黃蜂','Chicago Bulls':'芝加哥公牛','Cleveland Cavaliers':'克里夫蘭騎士','Dallas Mavericks':'達拉斯獨行俠','Denver Nuggets':'丹佛金塊','Detroit Pistons':'底特律活塞','Golden State Warriors':'金州勇士','Houston Rockets':'休士頓火箭','Indiana Pacers':'印第安納溜馬','LA Clippers':'洛杉磯快艇','Los Angeles Clippers':'洛杉磯快艇','Los Angeles Lakers':'洛杉磯湖人','LA Lakers':'洛杉磯湖人','Memphis Grizzlies':'曼菲斯灰熊','Miami Heat':'邁阿密熱火','Milwaukee Bucks':'密爾瓦基公鹿','Minnesota Timberwolves':'明尼蘇達灰狼','New Orleans Pelicans':'紐奧良鵜鶘','New York Knicks':'紐約尼克','Oklahoma City Thunder':'奧克拉荷馬雷霆','Orlando Magic':'奧蘭多魔術','Philadelphia 76ers':'費城76人','Phoenix Suns':'鳳凰城太陽','Portland Trail Blazers':'波特蘭拓荒者','Sacramento Kings':'沙加緬度國王','San Antonio Spurs':'聖安東尼奧馬刺','Toronto Raptors':'多倫多暴龍','Utah Jazz':'猶他爵士','Washington Wizards':'華盛頓巫師'},
  mlb: {'Arizona Diamondbacks':'亞利桑那響尾蛇','Athletics':'運動家','Oakland Athletics':'奧克蘭運動家','Atlanta Braves':'亞特蘭大勇士','Baltimore Orioles':'巴爾的摩金鶯','Boston Red Sox':'波士頓紅襪','Chicago Cubs':'芝加哥小熊','Chicago White Sox':'芝加哥白襪','Cincinnati Reds':'辛辛那提紅人','Cleveland Guardians':'克里夫蘭守護者','Colorado Rockies':'科羅拉多落磯','Detroit Tigers':'底特律老虎','Houston Astros':'休士頓太空人','Kansas City Royals':'堪薩斯市皇家','Los Angeles Angels':'洛杉磯天使','Los Angeles Dodgers':'洛杉磯道奇','Miami Marlins':'邁阿密馬林魚','Milwaukee Brewers':'密爾瓦基釀酒人','Minnesota Twins':'明尼蘇達雙城','New York Mets':'紐約大都會','New York Yankees':'紐約洋基','Philadelphia Phillies':'費城費城人','Pittsburgh Pirates':'匹茲堡海盜','San Diego Padres':'聖地牙哥教士','San Francisco Giants':'舊金山巨人','Seattle Mariners':'西雅圖水手','St. Louis Cardinals':'聖路易紅雀','Tampa Bay Rays':'坦帕灣光芒','Texas Rangers':'德州遊騎兵','Toronto Blue Jays':'多倫多藍鳥','Washington Nationals':'華盛頓國民'}
};

const scoreboardCache = new Map();
let currentOffsetDays = 0;

const CLOUD_API_BASE = window.CLOUD_API_BASE || 'https://nba-mlb-cloud.onrender.com';
const RECORD_STORAGE_KEY = 'nba_mlb_models_daily_results_v2';
const MODEL_LABELS = {
  'EDGE讓分結果':'statEdgeSpreadRate',
  'EDGE大小結果':'statEdgeTotalRate',
  '近10讓分結果':'statL10SpreadRate',
  '主客讓分結果':'statHASpreadRate',
  '近10大小_淨值結果':'statL10TotalNetRate',
  '近10大小_相加結果':'statL10TotalSumRate',
  '主客大小_淨值結果':'statHATotalNetRate',
  '主客大小_相加結果':'statHATotalSumRate'
};
function setActivePage(page) {
  const showRecommend = page === 'recommend';
  const showNear10 = page === 'near10';
  const showStats = page === 'stats';
  recommendPage.classList.toggle('hidden', !showRecommend);
  near10Page.classList.toggle('hidden', !showNear10);
  statsPage.classList.toggle('hidden', !showStats);
  recommendTabBtn.classList.toggle('active', showRecommend);
  near10TabBtn.classList.toggle('active', showNear10);
  statsTabBtn.classList.toggle('active', showStats);
  if (showStats) updateRecordSummary();
}
function getSeasonYearByLeague(leagueName, iso) {
  const d = new Date(iso || Date.now());
  const y = Number(new Intl.DateTimeFormat('en-CA',{timeZone:'Asia/Taipei',year:'numeric'}).format(d));
  const m = Number(new Intl.DateTimeFormat('en-CA',{timeZone:'Asia/Taipei',month:'2-digit'}).format(d));
  if (leagueName === 'NBA') return m >= 9 ? y + 1 : y;
  return y;
}
function getTaipeiParts(input) {
  const d = new Date(input || Date.now());
  const parts = new Intl.DateTimeFormat('en-US', {
    timeZone:'Asia/Taipei',
    year:'numeric',
    month:'2-digit',
    day:'2-digit',
    hour:'2-digit',
    minute:'2-digit',
    second:'2-digit',
    hour12:false
  }).formatToParts(d).reduce((acc, part) => {
    if (part.type !== 'literal') acc[part.type] = part.value;
    return acc;
  }, {});
  return parts;
}
function toTaipeiDateKey(iso) {
  if (!iso) return '';
  const p = getTaipeiParts(iso);
  return `${p.year}-${p.month}-${p.day}`;
}
function taiwanTime(){
  const p = getTaipeiParts();
  return `${p.year}-${p.month}-${p.day}T${p.hour}:${p.minute}:${p.second}+08:00`;
}

function toFinalScoreText(event) {
  const competitors = ((event?.competitions?.[0]?.competitors) || []).slice().sort((a,b)=>{
    if (a.homeAway === 'away') return -1;
    if (b.homeAway === 'away') return 1;
    return 0;
  });
  if (competitors.length < 2) return '';
  const leftScore = Number(competitors[0]?.score);
  const rightScore = Number(competitors[1]?.score);
  if (!Number.isFinite(leftScore) || !Number.isFinite(rightScore)) return '';
  return `${leftScore}:${rightScore}`;
}
function readRecordStore() {
  try { return JSON.parse(localStorage.getItem(RECORD_STORAGE_KEY) || '{}'); }
  catch (err) { return {}; }
}
function writeRecordStore(data) {
  localStorage.setItem(RECORD_STORAGE_KEY, JSON.stringify(data));
}
function savePickResultLocal(payload) {
  if (!payload?.比賽日期 || !payload?.比賽ID) return;
  const store = readRecordStore();
  if (!store[payload.比賽日期]) store[payload.比賽日期] = {};
  store[payload.比賽日期][payload.比賽ID] = payload;
  writeRecordStore(store);
}
function buildPeriodSummaryFromRows(rows, resultKey, mode) {
  const now = new Date();
  const tpNow = new Date(now.toLocaleString('en-US', { timeZone:'Asia/Taipei' }));
  const curY = tpNow.getFullYear();
  const curM = tpNow.getMonth();
  const day = tpNow.getDay();
  const mondayOffset = day === 0 ? -6 : 1 - day;
  const weekStart = new Date(tpNow); weekStart.setHours(0,0,0,0); weekStart.setDate(tpNow.getDate() + mondayOffset);
  let win=0, lose=0, push=0;
  rows.forEach(item => {
    const result = String(item?.[resultKey] || '').toUpperCase();
    if (!result) return;
    const dt = item?.比賽日期 ? new Date(`${item.比賽日期}T00:00:00+08:00`) : null;
    if (!dt || Number.isNaN(dt.getTime())) return;
    if (mode === 'week' && dt < weekStart) return;
    if (mode === 'month' && (dt.getFullYear() !== curY || dt.getMonth() !== curM)) return;
    if (result === 'WIN') win++;
    else if (result === 'LOSE') lose++;
    else if (result === 'PUSH') push++;
  });
  const graded = win + lose;
  return graded ? `${(win/graded*100).toFixed(1)}%` : '0%';
}
function renderSummaryFromRows(rows) {
  Object.entries(MODEL_LABELS).forEach(([resultKey, elId]) => {
    const el = document.getElementById(elId);
    if (!el) return;
    const week = buildPeriodSummaryFromRows(rows, resultKey, 'week');
    const month = buildPeriodSummaryFromRows(rows, resultKey, 'month');
    const season = buildPeriodSummaryFromRows(rows, resultKey, 'season');
    el.textContent = `週${week}｜月${month}｜季${season}`;
  });
}
async function updateRecordSummary() {
  const leagues = [];
  if (nbaToggle.checked) leagues.push('NBA');
  if (mlbToggle.checked) leagues.push('MLB');
  if (!leagues.length) return;
  statsStatusEl.textContent = '統計更新中...';
  const rows = [];
  for (const league of leagues) {
    const season = getSeasonYearByLeague(league, new Date().toISOString());
    try {
      const res = await fetch(`${CLOUD_API_BASE}/stats?league=${encodeURIComponent(league)}&season=${encodeURIComponent(season)}`, { cache:'no-store' });
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const data = await res.json();
      if (data?.ok && Array.isArray(data.rows)) rows.push(...data.rows);
    } catch (err) {}
  }
  if (rows.length) {
    renderSummaryFromRows(rows);
    statsStatusEl.textContent = '統計已從雲端更新';
    return;
  }
  const store = readRecordStore();
  const localRows = Object.values(store).flatMap(day => Object.values(day || {}));
  renderSummaryFromRows(localRows);
  statsStatusEl.textContent = localRows.length ? '雲端失敗，已改讀本機備援' : '目前尚無統計資料';
}
async function syncResultToCloud(payload) {
  try {
    await fetch(`${CLOUD_API_BASE}/save_result`, {
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body: JSON.stringify(payload)
    });
  } catch (err) {
    console.warn('同步雲端失敗', err);
  }
}
function avgPair(avgObj) {
  return {
    pf: Number(avgObj?.pf ?? 0),
    pa: Number(avgObj?.pa ?? 0)
  };
}
function modelSpreadPick(leftAvg, rightAvg, market, leftName, rightName) {
  const leftNet = Number(leftAvg?.pf ?? 0) - Number(leftAvg?.pa ?? 0);
  const rightNet = Number(rightAvg?.pf ?? 0) - Number(rightAvg?.pa ?? 0);
  if (leftNet === rightNet) return 'PASS';
  if (market?.favoriteSide === 'left') return leftNet > rightNet ? `${leftName} 讓分` : `${rightName} 受讓`;
  if (market?.favoriteSide === 'right') return rightNet > leftNet ? `${rightName} 讓分` : `${leftName} 受讓`;
  return leftNet > rightNet ? `${leftName} 讓分` : `${rightName} 讓分`;
}
function modelTotalByNet(leftAvg, rightAvg) {
  const leftNet = Number(leftAvg?.pf ?? 0) - Number(leftAvg?.pa ?? 0);
  const rightNet = Number(rightAvg?.pf ?? 0) - Number(rightAvg?.pa ?? 0);
  const highScoreTeam = Number(leftAvg?.pf ?? 0) >= Number(rightAvg?.pf ?? 0) ? 'left' : 'right';
  const highNetTeam = leftNet >= rightNet ? 'left' : 'right';
  return highScoreTeam === highNetTeam ? '大分' : '小分';
}
function modelTotalBySum(leftAvg, rightAvg) {
  const leftSum = Number(leftAvg?.pf ?? 0) + Number(leftAvg?.pa ?? 0);
  const rightSum = Number(rightAvg?.pf ?? 0) + Number(rightAvg?.pa ?? 0);
  const highScoreTeam = Number(leftAvg?.pf ?? 0) >= Number(rightAvg?.pf ?? 0) ? 'left' : 'right';
  const highSum = highScoreTeam === 'left' ? leftSum : rightSum;
  const lowSum = highScoreTeam === 'left' ? rightSum : leftSum;
  return highSum > lowSum ? '小分' : '大分';
}
function judgePickResult(event, market, pick, leftName, rightName) {
  const comp = event?.competitions?.[0];
  const competitors = (comp?.competitors || []).slice().sort((a,b)=>{
    if (a.homeAway === 'away') return -1;
    if (b.homeAway === 'away') return 1;
    return 0;
  });
  if (competitors.length < 2 || !event?.status?.type?.completed || !pick || pick === 'PASS') return '';
  const leftScore = Number(competitors[0]?.score);
  const rightScore = Number(competitors[1]?.score);
  if (!Number.isFinite(leftScore) || !Number.isFinite(rightScore)) return '';
  const diff = leftScore - rightScore;
  const total = leftScore + rightScore;
  if (pick === '大分') {
    if (market?.total == null) return '';
    return total > market.total ? 'WIN' : (total < market.total ? 'LOSE' : 'PUSH');
  }
  if (pick === '小分') {
    if (market?.total == null) return '';
    return total < market.total ? 'WIN' : (total > market.total ? 'LOSE' : 'PUSH');
  }
