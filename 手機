const near10Page = document.getElementById('near10Page');
const statsPage = document.getElementById('statsPage');
const near10ContentEl = document.getElementById('near10Content');
const near10StatusEl = document.getElementById('near10Status');
const statsStatusEl = document.getElementById('statsStatus');

const CONFIG = {
  nba: { key:'nba', name:'NBA', sport:'basketball', league:'nba', lookbackDays:40, totalEdge:8, spreadEdge:3.5, highTotal:235 },
  mlb: { key:'mlb', name:'MLB', sport:'baseball', league:'mlb', lookbackDays:25, totalEdge:1.2, spreadEdge:0.8, highTotal:11.5 }
