    button:disabled { opacity:.65; cursor:not-allowed; }
    .btn-primary { background:var(--btn); }
    .btn-secondary { background:var(--btn2); }
    .muted { color:var(--muted); font-size:13px; }
    .status { width:100%; }
    .league-toggle { display:inline-flex; align-items:center; gap:6px; padding:8px 11px; border:1px solid var(--line); border-radius:999px; background:#f6f8f5; font-size:14px; color:#415467; }    .grid { display:grid; gap:14px; }
    .match { padding:14px; }
    .topline { display:flex; justify-content:space-between; gap:8px; align-items:flex-start; flex-wrap:wrap; margin-bottom:10px; }
    .title { font-size:18px; font-weight:800; line-height:1.35; }
    .sub { color:var(--muted); font-size:13px; margin-top:2px; }
    .tag { display:inline-block; border:1px solid #d9e0d8; background:#f7f8f3; border-radius:999px; padding:5px 10px; font-size:12px; color:#42556a; font-weight:700; }
    .error { color:#b91c1c; background:#fef2f2; border:1px solid #fecaca; padding:11px 13px; border-radius:12px; }
    .note { color:#92400e; background:#fffbeb; border:1px solid #fde68a; padding:11px 13px; border-radius:12px; }
    .versus-card { margin-top:10px; border:1px solid var(--line); border-radius:18px; overflow:hidden; background:#f7f8f2; }
    .versus-head { display:grid; grid-template-columns:1fr auto 1fr; align-items:center; text-align:center; background:#eef1e6; border-bottom:1px solid var(--line); }
    .versus-team-title { padding:14px 10px; font-size:19px; font-weight:800; color:#34546f; letter-spacing:.3px; }
    .versus-time { padding:14px 10px; font-size:15px; color:#667085; font-weight:700; white-space:nowrap; }
    .versus-table { width:100%; border-collapse:collapse; table-layout:fixed; }
    .versus-table td { border-bottom:1px solid #e0e5db; padding:11px 9px; text-align:center; font-size:14px; background:#fbfbf7; }
    .versus-table tr:nth-child(even) td:not(.stat-name) { background:#f8f9f4; }
    .versus-table tr:last-child td { border-bottom:0; }
    .stat-name { color:#667085; width:30%; background:#eff2e8 !important; font-size:14px; }
    .team-side { width:35%; }
    .small-top { font-size:12px; color:#7b8669; font-weight:700; display:block; margin-bottom:2px; }
    .team-role { color:#556271; font-size:13px; margin-left:4px; }
    .stat-main { font-size:17px; font-weight:800; color:#314256; letter-spacing:.2px; }
    .net-positive { color:#c2410c; font-weight:900; }
    .sum-alert { color:var(--alert); }
    .footer-note { margin-top:9px; font-size:12px; color:var(--muted); }
    .bet-box { margin-top:10px; padding:11px 12px; border:1px solid var(--line); border-radius:14px; background:#f8faf6; }
    .bet-head { display:flex; justify-content:space-between; gap:8px; align-items:center; flex-wrap:wrap; margin-bottom:6px; }
    .bet-pick { font-weight:800; color:#2e465c; }
    .bet-meta { font-size:12px; color:#667085; }
    .bet-sub { font-size:13px; color:#556271; margin-top:4px; }
    .bet-strong { color:#b45309; }
    .bet-pass { color:#6b7280; }
    .mark-red { color:#b91c1c; font-weight:800; }
    .window-note {
      width:100%;
      font-size:13px;
      color:#556271;
      padding:4px 2px 0;
