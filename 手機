async function getTeamRecentGamesByScoreboards(conf, teamId, cutoffInput) {
  const out = [];
  const seen = new Set();
  const cutoffMs = new Date(cutoffInput).getTime();
  const cutoffDate = new Date(cutoffMs);
  for (let i=0; i<=conf.lookbackDays; i++) {
    const d = dateMinusDays(cutoffDate, i);
    const yyyymmdd = fmtDate(d);
    let events = [];
    try {
      events = await getScoreboard(conf, yyyymmdd);
    } catch (err) {
      console.warn('scoreboard 日資料失敗', conf.key, yyyymmdd, err);
      continue;
    }
    for (const ev of events) {
      const game = getCompletedGameForTeam(conf, ev, teamId, cutoffMs);
      if (game && !seen.has(game.id)) {
        seen.add(game.id);
        out.push(game);
      }
    }
    if (out.length >= 12) break;
  }
  out.sort((a,b)=>b.gameMs-a.gameMs);
  return out.slice(0,10);
}

