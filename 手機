function buildNear10Card(leagueName, leagueKey, event, teamStatsMap) {
  const comp = event?.competitions?.[0];
  let competitors = (comp?.competitors || []).slice();
  competitors = competitors.sort((a,b)=>{
    if (a.homeAway === 'away') return -1;
    if (b.homeAway === 'away') return 1;
    return 0;
  });

  const rows = competitors.map(c => {
    const teamId = String(c?.team?.id || '');
    const stats = teamStatsMap.get(teamId) || [];
    const side = c?.homeAway || null;
    const sideStats = stats.filter(g => !side || g.homeAway === side);
    const avgAll = getWindowAverages(stats, 10);
    const avgSide = getWindowAverages(sideStats, 10);
    const netAll = avgAll ? avgAll.pf - avgAll.pa : null;
    const netSide = avgSide ? avgSide.pf - avgSide.pa : null;
    const sumAll = avgAll ? avgAll.pf + avgAll.pa : null;
    const sumSide = avgSide ? avgSide.pf + avgSide.pa : null;
    const countAllEnough = stats.length >= 10;
    const countSideEnough = sideStats.length >= 10;
    const passAll = !!(countAllEnough && avgAll && netAll > 0);
    const passSide = !!(countSideEnough && avgSide && netSide > 0);
    return {
      name: teamNameZh(leagueKey, c?.team),
      side: c?.homeAway === 'home' ? '主隊' : (c?.homeAway === 'away' ? '客隊' : ''),
      allCount: stats.length,
      sideCount: sideStats.length,
      avgAll, avgSide, netAll, netSide, sumAll, sumSide,
      countAllEnough, countSideEnough, passAll, passSide
    };
  });

  const left = rows[0] || {};
  const right = rows[1] || {};

  const allEnough = left.countAllEnough && right.countAllEnough;
  const sideEnough = left.countSideEnough && right.countSideEnough;
  const allEligible = left.passAll && right.passAll;
  const sideEligible = left.passSide && right.passSide;
  const allInsufficient = !allEnough;
  const sideInsufficient = !sideEnough;

  // 整張卡規則：只有近10或主客近10任一組「雙方淨值都正」才顯示；否則整張隱藏
  if (!(allEligible || sideEligible)) return null;

  function fmtAvg(avgObj, enough) {
    if (!enough) return '場數不足';
    return avgObj ? `${round1(avgObj.pf)}/${round1(avgObj.pa)}` : '-';
  }
  function fmtNet(v, enough) {
    if (!enough) return '場數不足';
    return v === null || v === undefined ? '-' : `${v >= 0 ? '+' : ''}${round1(v)}`;
  }
  function fmtSum(v, enough) {
    if (!enough) return '場數不足';
    return v === null || v === undefined ? '-' : round1(v);
  }
  function redWrap(s) {
    return `<span class="mark-red">${s}</span>`;
  }
  function netClass(value, otherValue, enabled) {
    if (!enabled || value === null || otherValue === null) return '';
    return value > otherValue ? 'mark-red' : '';
  }
  function sumClass(value, otherValue, enabled) {
    if (!enabled || value === null || otherValue === null) return '';
    return value > otherValue ? 'mark-red' : '';
  }
  function spreadText(a, b, enabled, enough) {
    if (!enough) return '場數不足';
    if (!enabled || a === null || b === null) return '—';
    return a >= b ? redWrap(`${left.name} 讓分較強`) : redWrap(`${right.name} 讓分較強`);
  }
  function totalByNet(aAvg, bAvg, aNet, bNet, enabled, enough) {
    if (!enough) return '場數不足';
    if (!enabled || !aAvg || !bAvg || aNet === null || bNet === null) return '—';
    const highScoreTeam = aAvg.pf >= bAvg.pf ? 'left' : 'right';
    const highNetTeam = aNet >= bNet ? 'left' : 'right';
    return highScoreTeam === highNetTeam ? redWrap('小分') : redWrap('大分');
  }
  function totalBySum(aAvg, bAvg, aSum, bSum, enabled, enough) {
    if (!enough) return '場數不足';
    if (!enabled || !aAvg || !bAvg || aSum === null || bSum === null) return '—';
    const highScoreTeam = aAvg.pf >= bAvg.pf ? 'left' : 'right';
    const highScoreSum = highScoreTeam === 'left' ? aSum : bSum;
    const lowScoreSum = highScoreTeam === 'left' ? bSum : aSum;
    return highScoreSum > lowScoreSum ? redWrap('小分') : redWrap('大分');
  }
  function shortTime(iso) {
    return new Intl.DateTimeFormat('zh-TW',{
      timeZone:'Asia/Taipei',
      month:'2-digit',
      day:'2-digit',
      hour:'2-digit',
      minute:'2-digit',
      hour12:false
    }).format(new Date(iso));
  }

  const card = document.createElement('div');
  card.className = 'card match';
  card.innerHTML = `
    <div class="topline">
      <div>
        <div class="title">${left.name || '-'} vs ${right.name || '-'}</div>
        <div class="sub">${leagueName}｜台灣時間 ${shortTime(event.date)}</div>
      </div>
      <div class="tag">近10 / 主客近10</div>
    </div>
    <div class="versus-card">
      <table class="versus-table">
        <tr>
          <td class="team-side"><span class="small-top">${leagueName}</span>${left.side ? `<span class="team-role">${left.side}</span>` : ''}</td>
          <td class="stat-name">項目</td>
          <td class="team-side"><span class="small-top">${leagueName}</span>${right.side ? `<span class="team-role">${right.side}</span>` : ''}</td>
        </tr>
        <tr>
          <td><span class="stat-main">${fmtAvg(left.avgAll, allEnough)}</span></td>
          <td class="stat-name">近10平均得 / 失分</td>
          <td><span class="stat-main">${fmtAvg(right.avgAll, allEnough)}</span></td>
        </tr>
        <tr>
          <td><span class="stat-main ${netClass(left.netAll, right.netAll, allEligible)}">${fmtNet(left.netAll, allEnough)}</span></td>
          <td class="stat-name">近10淨值</td>
          <td><span class="stat-main ${netClass(right.netAll, left.netAll, allEligible)}">${fmtNet(right.netAll, allEnough)}</span></td>
        </tr>
        <tr>
          <td><span class="stat-main ${sumClass(left.sumAll, right.sumAll, allEligible)}">${fmtSum(left.sumAll, allEnough)}</span></td>
          <td class="stat-name">近10相加</td>
          <td><span class="stat-main ${sumClass(right.sumAll, left.sumAll, allEligible)}">${fmtSum(right.sumAll, allEnough)}</span></td>
        </tr>
        <tr>
          <td><span class="stat-main">${fmtAvg(left.avgSide, sideEnough)}</span></td>
          <td class="stat-name">主客近10平均得 / 失分</td>
          <td><span class="stat-main">${fmtAvg(right.avgSide, sideEnough)}</span></td>
        </tr>
        <tr>
          <td><span class="stat-main ${netClass(left.netSide, right.netSide, sideEligible)}">${fmtNet(left.netSide, sideEnough)}</span></td>
          <td class="stat-name">主客近10淨值</td>
          <td><span class="stat-main ${netClass(right.netSide, left.netSide, sideEligible)}">${fmtNet(right.netSide, sideEnough)}</span></td>
        </tr>
        <tr>
          <td><span class="stat-main ${sumClass(left.sumSide, right.sumSide, sideEligible)}">${fmtSum(left.sumSide, sideEnough)}</span></td>
          <td class="stat-name">主客近10相加</td>
          <td><span class="stat-main ${sumClass(right.sumSide, left.sumSide, sideEligible)}">${fmtSum(right.sumSide, sideEnough)}</span></td>
        </tr>
      </table>
    </div>
    <div class="bet-box">
      <div class="bet-head"><div class="bet-pick">近10讓分：${spreadText(left.netAll, right.netAll, allEligible, allEnough)}</div></div>
      <div class="bet-sub">近10大小淨值：${totalByNet(left.avgAll, right.avgAll, left.netAll, right.netAll, allEligible, allEnough)}</div>
      <div class="bet-sub">近10大小相加：${totalBySum(left.avgAll, right.avgAll, left.sumAll, right.sumAll, allEligible, allEnough)}</div>
      <div class="bet-sub">主客讓分：${spreadText(left.netSide, right.netSide, sideEligible, sideEnough)}</div>
      <div class="bet-sub">主客大小淨值：${totalByNet(left.avgSide, right.avgSide, left.netSide, right.netSide, sideEligible, sideEnough)}</div>
      <div class="bet-sub">主客大小相加：${totalBySum(left.avgSide, right.avgSide, left.sumSide, right.sumSide, sideEligible, sideEnough)}</div>
    </div>`;
  return card;
}

async function loadGames(offsetDays) {
  currentOffsetDays = offsetDays;
  try {
    setBusy(true);
    contentEl.innerHTML = '';
    near10ContentEl.innerHTML = '';
    statusEl.textContent = '更新中...';
    near10StatusEl.textContent = '更新中...';
    const now = new Date();
    const target = new Date(now.getFullYear(), now.getMonth(), now.getDate());
    target.setDate(target.getDate() + offsetDays);
    const yyyymmdd = fmtDate(target);

    const leagues = [];
    if (nbaToggle.checked) leagues.push(CONFIG.nba);
    if (mlbToggle.checked) leagues.push(CONFIG.mlb);
    if (!leagues.length) { statusEl.textContent = '請至少勾選一個聯盟'; return; }

    let totalMatches = 0;
    let filledRows = 0;
    const candidateCards = [];

    for (const conf of leagues) {
      statusEl.textContent = `更新中：抓 ${conf.name} 賽程...`;
      const rawEvents = await getScoreboard(conf, yyyymmdd);
      const officialEvents = rawEvents.filter(ev => (ev.competitions?.[0]?.competitors || []).length >= 2 && isOfficialGame(conf, ev));
      const fallbackEvents = rawEvents.filter(ev => (ev.competitions?.[0]?.competitors || []).length >= 2);
      const events = officialEvents.length ? officialEvents : fallbackEvents;

      if (!events.length) {
        contentEl.insertAdjacentHTML('beforeend', `<div class="card match muted">${conf.name} 這天沒有可顯示賽程。</div>`);
        near10ContentEl.insertAdjacentHTML('beforeend', `<div class="card match muted">${conf.name} 這天沒有可顯示賽程。</div>`);
        continue;
      }

      if (!officialEvents.length && fallbackEvents.length) {
        contentEl.insertAdjacentHTML('beforeend', `<div class="note">${conf.name} 這天抓不到明確正式賽標記，已改成全部賽程都顯示。</div>`);
        near10ContentEl.insertAdjacentHTML('beforeend', `<div class="note">${conf.name} 這天抓不到明確正式賽標記，已改成全部賽程都顯示。</div>`);
      }

      for (let idx=0; idx<events.length; idx++) {
        const event = events[idx];
        const competitors = (event.competitions?.[0]?.competitors || []).filter(c => c?.team?.id);
        if (competitors.length < 2) continue;

        statusEl.textContent = `更新中：${conf.name} ${idx+1}/${events.length} ${competitors.map(c => teamNameZh(conf.key, c.team)).join(' vs ')}`;
        const statsEntries = await Promise.all(
          competitors.map(async c => [String(c.team.id), await getTeamRecentGamesByScoreboards(conf, c.team.id, event.date)])
        );

        const teamStatsMap = new Map(statsEntries);
        for (const [, stats] of statsEntries) if (stats.length) filledRows++;

        const card = buildMatchCard(conf.name, conf.key, event, teamStatsMap);
        const near10Card = buildNear10Card(conf.name, conf.key, event, teamStatsMap);
        if (near10Card) near10ContentEl.appendChild(near10Card);
        if (card.dataset.show === '1') {
          candidateCards.push(card);
          totalMatches++;
        }
      }
    }

    candidateCards
      .sort((a, b) => Number(b.dataset.rank || 0) - Number(a.dataset.rank || 0))
      .forEach(card => contentEl.appendChild(card));

    if (!totalMatches) {
      const targetLabel = offsetDays === 0 ? '今天' : '明天';
      contentEl.innerHTML = `<div class="card match muted">${targetLabel} 目前沒有達到EDGE門檻的場次。</div>`;
    } else if (!filledRows) {
      contentEl.insertAdjacentHTML('afterbegin', `<div class="note">賽程有抓到，但近期得失分仍為空白。這通常代表瀏覽器把外部資料請求擋住了。</div>`);
      near10ContentEl.insertAdjacentHTML('afterbegin', `<div class="note">賽程有抓到，但近期得失分仍為空白。這通常代表瀏覽器把外部資料請求擋住了。</div>`);
    }
    if (!near10ContentEl.children.length) {
      const targetLabel = offsetDays === 0 ? '今天' : '明天';
      near10ContentEl.innerHTML = `<div class="card match muted">${targetLabel} 沒有可顯示的近10 / 主客近10資料。</div>`;
    }

    statusEl.textContent = `最後更新：${new Date().toLocaleString('zh-TW',{hour12:false})}`;
    near10StatusEl.textContent = `最後更新：${new Date().toLocaleString('zh-TW',{hour12:false})}`;
  } catch (err) {
    console.error(err);
    contentEl.innerHTML = `<div class="error">更新失敗。若反覆失敗，多半是瀏覽器或代理暫時擋住外部請求。</div>`;
    near10ContentEl.innerHTML = `<div class="error">更新失敗。若反覆失敗，多半是瀏覽器或代理暫時擋住外部請求。</div>`;
    statusEl.textContent = '更新失敗';
    near10StatusEl.textContent = '更新失敗';
  } finally {
    setBusy(false);
  }
}
todayBtn.addEventListener('click', ()=>loadGames(0));
tomorrowBtn.addEventListener('click', ()=>loadGames(1));
nbaToggle.addEventListener('change', ()=>{ loadGames(currentOffsetDays); if (!statsPage.classList.contains('hidden')) updateRecordSummary(); });
mlbToggle.addEventListener('change', ()=>{ loadGames(currentOffsetDays); if (!statsPage.classList.contains('hidden')) updateRecordSummary(); });
recommendTabBtn.addEventListener('click', ()=>setActivePage('recommend'));
near10TabBtn.addEventListener('click', ()=>setActivePage('near10'));
statsTabBtn.addEventListener('click', ()=>setActivePage('stats'));

loadGames(0);
</script>
