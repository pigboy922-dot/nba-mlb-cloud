    '主客大小_淨值結果': sideEligible ? judgePickResult(event, market, modelPicks['主客大小_淨值推薦'], left.name, right.name) : '',
    '主客大小_相加結果': sideEligible ? judgePickResult(event, market, modelPicks['主客大小_相加推薦'], left.name, right.name) : '',
    'EDGE讓分結果': judgePickResult(event, market, modelPicks['EDGE讓分推薦'], left.name, right.name),
    'EDGE大小結果': judgePickResult(event, market, modelPicks['EDGE大小推薦'], left.name, right.name)
  };
  const seasonYear = getSeasonYearByLeague(leagueName, event.date);
  const payload = {
    '比賽ID': gameId,
