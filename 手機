  const allEligible = allCountEnough && (Number(left.net10_all) > 0) && (Number(right.net10_all) > 0);
  const sideEligible = sideCountEnough && (Number(left.net10_side) > 0) && (Number(right.net10_side) > 0);
  const modelPicks = {
