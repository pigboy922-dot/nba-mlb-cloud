    .page-tabs { width:100%; display:flex; gap:8px; }
    .page-tab { flex:1; background:#e8edf1; color:#355067; border:1px solid var(--line); }
    .page-tab.active { background:#345a74; color:#fff; border-color:#345a74; box-shadow:0 6px 16px rgba(52,90,116,.18); }
    .page-panel.hidden { display:none; }
