    .wrap { max-width:760px; margin:0 auto; padding:14px; }
    .toolbar,.card { background:rgba(252,252,248,.96); border:1px solid var(--line); border-radius:18px; box-shadow:0 8px 24px rgba(36,52,71,.06); }
    .toolbar { padding:14px; display:flex; gap:10px; flex-wrap:wrap; align-items:center; margin-bottom:14px; position:sticky; top:0; z-index:9; backdrop-filter:blur(8px); }
    h1 { font-size:20px; width:100%; margin:0 0 2px 0; color:#2e465c; letter-spacing:.3px; }
