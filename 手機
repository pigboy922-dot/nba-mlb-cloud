    '對戰': `${left.name} vs ${right.name}`,
    '主隊': right.name,
    '客隊': left.name,
    '最終比分': toFinalScoreText(event),
    '判定時間': taiwanTime(),
    '更新時間': taiwanTime(),
    '讓分盤': market.spread != null ? round1(market.spread) : '',
    '大小分盤': market.total != null ? round1(market.total) : '',
    'EDGE讓分值': modelPicks['EDGE讓分推薦'] !== 'PASS' ? round1(Math.abs(Number(suggestion.displayEdge || 0))) : '',
    'EDGE大小值': modelPicks['EDGE大小推薦'] !== 'PASS' ? round1(Math.abs(Number(suggestion.displayEdge || 0))) : '',
    ...modelPicks,
    ...modelResults
  };
  const hasAnyPick = Object.values(modelPicks).some(v => v && v !== 'PASS');
  const hasAnyResult = Object.values(modelResults).some(v => !!v);
  const shouldWrite = hasAnyPick || hasAnyResult;

  if (shouldWrite) {
    savePickResultLocal(payload);
    syncResultToCloud(payload);
  }
  card.dataset.show = showStrong ? '1' : '0';
  card.dataset.rank = String(edgeRank);
  card.innerHTML = `
    <div class="topline">
      <div>
        <div class="sub">保留EDGE＋近10＋主客近10，不隱藏</div>
      </div>
      <div class="tag">${leagueName}</div>
    </div>
    <div class="versus-card">
      <div class="versus-head">
        <div class="versus-team-title">${left.name || '-'}</div>
        <div class="versus-time">${timeOnly(event.date)}</div>
